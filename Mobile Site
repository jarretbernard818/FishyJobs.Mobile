<script>
const scenes = [
  { num:"01", tag:"INTRO",    tagClass:"tag-intro",    title:"Cold Open / Episode Intro",      time:"0:00 – 1:30",   dur:"~1.5m", color:"#3fb950",
    rows:[["Type","On camera — at the pond location"],["Script","Jarret connects back to Ep 1, introduces today's topic with self-deprecating humor"],["Key beat","\"A pond that isn't maintained isn't a pond. It's just a really expensive puddle.\""],["Vibe","Confident but real — he's learning, not lecturing"]] },
  { num:"02", tag:"LOCATION", tagClass:"tag-location", title:"Voiceover / B-Roll Context",     time:"1:30 – 2:30",   dur:"~1m",   color:"#58a6ff",
    rows:[["Type",[["vo","b-vo"],"Voiceover over b-roll"]],["B-roll","Pond surface, filter systems, test kits, algae, pump close-ups"],["Key line","\"A healthy pond is a balancing act. Get one thing wrong and you feel it ripple through everything.\""],["Transition","Sets up the four pillars covered today"]] },
  { num:"03", tag:"MEET",     tagClass:"tag-meet",     title:"Meet the Expert",                time:"2:30 – 3:30",   dur:"~1m",   color:"#bc8cff",
    rows:[["Type","On camera — introductions"],["Who","Fitz Fish Ponds service/maintenance expert"],["Goal","Establish rapport; Jarret admits upfront he doesn't know this side of the job"],["Tone","Casual, funny if possible — set the expert up as the authority"]] },
  { num:"04", tag:"LEARN",    tagClass:"tag-learn",    title:"Water Testing Walkthrough",      time:"3:30 – 7:00",   dur:"~3.5m", color:"#3fb950",
    rows:[["Type",[["cam","b-cam"],"On camera + demo"]],["Topics","pH, ammonia, nitrite, nitrate, KH — what each means for fish health"],["Demo","Live water test on the pond; liquid kit and digital meter side by side"],["Key rule","Always test before treating — never guess and dose"],["Key moment","Jarret reacts to a bad reading — let it land naturally"]] },
  { num:"05", tag:"WORK",     tagClass:"tag-work",     title:"Filter Maintenance",             time:"7:00 – 12:00",  dur:"~5m",   color:"#f78166",
    rows:[["Type",[["work","b-work"],"Hands-on"]],["What","Pull filter media, show dirty vs healthy, clean it correctly"],["Warning",[["warn","b-warn"],"Never rinse bio media in tap water — kills the bacteria colony"]],["Key moment","Jarret does it wrong first — expert corrects him — keep it in"],["Shots","Close-up of media, water color change, before/after"]] },
  { num:"06", tag:"WORK",     tagClass:"tag-work",     title:"Algae Management",               time:"12:00 – 16:30", dur:"~4.5m", color:"#f78166",
    rows:[["Type",[["work","b-work"],"Hands-on + Q&A"]],["What","Manual string algae removal, then walk through how a UV clarifier works"],["Myth bust","Algaecides treat the symptom — explain nutrient overload instead"],["Ask expert","Is some algae actually okay? What's the tipping point?"],["Shots","Hands pulling algae, UV unit, green vs clear water comparison"]] },
  { num:"07", tag:"WORK",     tagClass:"tag-work",     title:"Partial Water Change",           time:"16:30 – 20:30", dur:"~4m",   color:"#f78166",
    rows:[["Type",[["work","b-work"],"Hands-on"]],["What","Pond vac debris, drain 15%, dechlorinate, temperature match, refill"],["Warning",[["warn","b-warn"],"100% water change destroys the nitrogen cycle — partial only, always"]],["Ask expert","How does dechlorinator actually work? What happens without it?"],["Mood","Satisfying — pond visibly looks better by the end"]] },
  { num:"08", tag:"FAQSEG",   tagClass:"tag-faq",      title:"Top 5 Viewer FAQs",             time:"20:30 – 23:00", dur:"~2.5m", color:"#d29922",
    rows:[["Format","Jarret asks expert — quick fire, one question at a time, natural answers"],["Q1","How often should I really be servicing my pond?"],["Q2","My water is green — what's the first thing I should do?"],["Q3","My fish are gasping at the surface — is that serious?"],["Q4","Can I just use tap water for a water change?"],["Q5","How do I know if my filter is actually doing its job?"]] },
  { num:"09", tag:"OUTRO",    tagClass:"tag-outro",    title:"Say Goodbye to the Crew",       time:"23:00 – 23:30", dur:"~30s",  color:"#8b949e",
    rows:[["Type","On camera — candid"],["What","Natural, unscripted goodbyes"],["Vibe","Show the team dynamic — these are real people Jarret works with"]] },
  { num:"10", tag:"OUTRO",    tagClass:"tag-outro",    title:"Reflection & Next Episode Tease",time:"23:30 – 25:00", dur:"~1.5m", color:"#8b949e",
    rows:[["Type","On camera — solo, end of day"],["What","Honest reflection on what surprised him and what he actually learned"],["Key line","\"If you're a pond owner putting off maintenance… please don't. Your fish will thank you.\""],["Tease","\"Next time — we're not maintaining a pond. We're building one from scratch.\""]] },
];

const durations = [1.5,1,1,3.5,5,4.5,4,2.5,0.5,1.5];

const tl = document.getElementById('tl');
durations.forEach((d,i) => {
  const seg = document.createElement('div');
  seg.className = 'tl-seg';
  seg.style.cssText = `flex:${d};background:${scenes[i].color};opacity:0.6;`;
  tl.appendChild(seg);
});

const container = document.getElementById('scenes');
scenes.forEach((s,i) => {
  const card = document.createElement('div');
  card.className = 'card';

  const rowsHtml = s.rows.map(([k,...vals]) => {
    let valHtml = '';
    vals.forEach(v => {
      if (Array.isArray(v) && v.length===2 && typeof v[0]==='string' && typeof v[1]==='string') {
        valHtml += `<span class="badge b-${v[0]}">${v[0]}</span>${v[1]}`;
      } else { valHtml += v; }
    });
    return `<div class="row"><div class="row-key">${k}</div><div class="row-val">${valHtml}</div></div>`;
  }).join('');

  card.innerHTML = `
    <div class="card-header" onclick="toggle(${i})">
      <span class="seg-num">${s.num}</span>
      <span class="seg-tag ${s.tagClass}">${s.tag}</span>
      <div class="card-title-wrap">
        <div class="seg-title">${s.title}</div>
        <div class="seg-time">${s.time} · ${s.dur}</div>
      </div>
      <span class="chevron" id="chev-${i}">▶</span>
    </div>
    <div class="card-body" id="body-${i}">${rowsHtml}</div>`;
  container.appendChild(card);
});

function toggle(i) {
  document.getElementById('body-'+i).classList.toggle('open');
  document.getElementById('chev-'+i).classList.toggle('open');
}
toggle(0);

function switchTab(name, el) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  el.classList.add('active');
  window.scrollTo(0,0);
}
</script>
